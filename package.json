  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "compile:contracts": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json node --import tsx ./node_modules/hardhat/internal/cli/cli.js compile",
    "deploy:base-sepolia": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json node --import tsx ./node_modules/hardhat/internal/cli/cli.js run scripts/deploy-base-sepolia.ts --network baseSepolia",
