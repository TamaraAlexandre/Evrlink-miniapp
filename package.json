    "@tanstack/react-query": "^5.90.20",
    "@upstash/redis": "^1.36.2",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.7.0",
    "next": "16.1.6",
    "pinata": "^2.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.47.6",
    "wagmi": "^2.19.5"
  },
  "ts-node": {
